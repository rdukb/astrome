# Database
DATABASE_URL=sqlite:///./astrome.db

# Swiss Ephemeris
# Path to ephemeris data files for highest precision (0.001 arcsec, JPL DE431)
# Files successfully downloaded (1.9MB total): seas_18.se1, semo_18.se1, sepl_18.se1
# Leave empty to use built-in Moshier ephemeris (<0.1 arcsec precision) as fallback
EPHE_PATH=./src/data/ephe

# API Configuration
API_TITLE=Tamil Panchang API
API_VERSION=1.0.0
# Local dev origins + production Firebase Hosting URL (replace with your actual domain)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3453,https://astrome-prod.web.app,https://astrome-prod.firebaseapp.com

# Cache Configuration
CACHE_EXPIRY_DAYS=90

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/astrome.log

# Rate Limiting
RATE_LIMIT_ENABLED=false
RATE_LIMIT_PER_MINUTE=60
