rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      // Astrome v1 does not use Firestore for client-facing reads/writes.
      // All data access goes through the FastAPI backend on Cloud Run.
      // Deny all direct client access until collection-level auth rules are needed.
      allow read, write: if false;
    }
  }
}
