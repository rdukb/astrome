# Development environment — loaded by `next dev` only, NOT by `next build`
# This means production builds (firebase deploy, CI) will use .env.production instead

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_TIMEOUT=30000

# Feature Flags
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true
NEXT_PUBLIC_ENABLE_PWA=true

# Environment
NEXT_PUBLIC_ENV=development
