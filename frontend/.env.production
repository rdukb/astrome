# Production environment — Firebase Hosting proxies /api/** to Cloud Run
# Empty string tells api-client.ts to use relative paths (handled by Firebase rewrite rules)
NEXT_PUBLIC_API_URL=
# Analytics — set to your GA4 Measurement ID (G-XXXXXXXXXX) to enable tracking
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=true
NEXT_PUBLIC_ENABLE_PWA=true
NEXT_PUBLIC_ENV=production
